# Shared defaults for local backend development
NODE_ENV=development
LOG_LEVEL=debug

# Database engine
DB_ENGINE=postgresql

# Django
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SECRET_KEY=replace-me

# Gateway
GATEWAY_PORT=8080
GATEWAY_HOST=0.0.0.0

# Service hosts and ports
AUTH_SERVICE_PORT=4001
USERS_SERVICE_PORT=4002
TEAMS_SERVICE_PORT=4003
ASSIGNMENTS_SERVICE_PORT=4004
REPORTS_SERVICE_PORT=4005
DAILY_REPORTS_SERVICE_PORT=4006
DASHBOARD_SERVICE_PORT=4007

# Internal service URLs (gateway -> services)
AUTH_SERVICE_URL=http://localhost:4001
USERS_SERVICE_URL=http://localhost:4002
TEAMS_SERVICE_URL=http://localhost:4003
ASSIGNMENTS_SERVICE_URL=http://localhost:4004
REPORTS_SERVICE_URL=http://localhost:4005
DAILY_REPORTS_SERVICE_URL=http://localhost:4006
DASHBOARD_SERVICE_URL=http://localhost:4007

# Auth/session (choose actual values later)
JWT_ACCESS_SECRET=replace-me
JWT_REFRESH_SECRET=replace-me
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Per-service database URLs (recommended for microservices)
AUTH_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bluesky_auth
USERS_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bluesky_users
TEAMS_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bluesky_teams
ASSIGNMENTS_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bluesky_assignments
REPORTS_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bluesky_reports
DAILY_REPORTS_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bluesky_daily_reports

# Optional shared DB URL fallback
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bluesky
